default_platform(:ios)

platform :ios do
  desc "Build and upload to TestFlight"
  lane :beta do
    setup_ci

    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_P8"],
      is_key_content_base64: false,
      in_house: false,
    )

    # Write the API key to a file so xcodebuild can use it for
    # automatic provisioning during both archive and export.
    key_path = File.join(Dir.tmpdir, "AuthKey_#{ENV['ASC_KEY_ID']}.p8")
    File.write(key_path, ENV["ASC_KEY_P8"])

    update_code_signing_settings(
      use_automatic_signing: true,
      team_id: ENV["APPLE_TEAM_ID"],
      path: "Introibo.xcodeproj",
    )

    build_app(
      project: "Introibo.xcodeproj",
      scheme: "Introibo",
      export_method: "app-store",
      destination: "generic/platform=iOS",
      xcargs: "-allowProvisioningUpdates -authenticationKeyPath '#{key_path}' -authenticationKeyID '#{ENV['ASC_KEY_ID']}' -authenticationKeyIssuerID '#{ENV['ASC_ISSUER_ID']}'",
      export_options: {
        signingStyle: "automatic",
        teamID: ENV["APPLE_TEAM_ID"],
      },
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
    )
  end

  desc "Build only (CI check, no upload)"
  lane :build_only do
    build_app(
      project: "Introibo.xcodeproj",
      scheme: "Introibo",
      destination: "platform=iOS Simulator,name=iPhone 15,OS=latest",
      configuration: "Debug",
      skip_archive: true,
      xcargs: "CODE_SIGN_IDENTITY='' CODE_SIGNING_REQUIRED=NO CODE_SIGNING_ALLOWED=NO",
    )
  end
end
